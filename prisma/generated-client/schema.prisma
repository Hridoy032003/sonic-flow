generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  role      String     @default("USER")
  status    String     @default("ACTIVE")
  favorites Favorite[]
  history   History[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  music       Music[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Music {
  id         String     @id @default(cuid())
  title      String
  artist     String?
  durationMs Int        @default(0)
  srcUrl     String
  artworkUrl String?
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  status     String     @default("PUBLISHED")
  likes      Int        @default(0)
  downloads  Int        @default(0)
  shares     Int        @default(0)
  favorites  Favorite[]
  history    History[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  musicId   String
  music     Music    @relation(fields: [musicId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, musicId])
}

model History {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  musicId   String
  music     Music    @relation(fields: [musicId], references: [id])
  createdAt DateTime @default(now())
}

model SystemSettings {
  id              Int      @id @default(1)
  askSubscription Boolean  @default(true)
  defaultTheme    String   @default("light")
  updatedAt       DateTime @updatedAt
}
