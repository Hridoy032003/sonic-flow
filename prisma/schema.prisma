generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("USER") // USER or ADMIN
  status    String   @default("ACTIVE") // ACTIVE, BANNED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  music       Music[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Music {
  id          String    @id @default(cuid())
  title       String
  artist      String?
  durationMs  Int       @default(0)
  srcUrl      String
  artworkUrl  String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  status      String    @default("PUBLISHED") // PUBLISHED, HIDDEN
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
